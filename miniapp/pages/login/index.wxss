.login-page {
  min-height: 100vh;
  padding: 48rpx 28rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.14), transparent 32%),
    linear-gradient(180deg, #f6f9ff 0%, #eef6ff 40%, #f7fafc 100%);
}

.login-hero {
  padding: 42rpx 18rpx 34rpx;
}

.login-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.login-title {
  margin-top: 24rpx;
  font-size: 64rpx;
  font-weight: 700;
  color: #0f172a;
}

.login-subtitle {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}

.login-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 24rpx 48rpx rgba(15, 23, 42, 0.08);
}

.mode-switch {
  display: flex;
  gap: 16rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.mode-chip {
  flex: 1;
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.mode-chip-active {
  background: #ffffff;
  color: #0f172a;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.08);
}

.login-copy {
  margin: 28rpx 4rpx 20rpx;
  color: #64748b;
  line-height: 1.7;
  font-size: 26rpx;
}

.login-input {
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  color: #0f172a;
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
}

.primary-login-btn {
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 28rpx rgba(34, 197, 94, 0.22);
}

.primary-login-btn::after {
  border: none;
}

.switch-copy {
  margin-top: 20rpx;
  text-align: center;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.7;
}
