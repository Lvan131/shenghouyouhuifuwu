.recommend-hero {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fff4d6, #fff9eb);
}

.recommend-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #7c4a03;
}

.recommend-copy {
  margin-top: 12rpx;
  color: #8b6b37;
  line-height: 1.7;
}

.recommend-card {
  margin-bottom: 18rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdfa 100%);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.06);
}

.activity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-title {
  flex: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.distance-badge {
  min-width: 110rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #059669;
  font-size: 24rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
  box-shadow: inset 0 0 0 2rpx rgba(5, 150, 105, 0.08);
}

.activity-summary {
  margin-top: 18rpx;
  font-size: 34rpx;
  color: #475569;
  line-height: 1.5;
}

.activity-desc {
  margin-top: 14rpx;
  color: #64748b;
  line-height: 1.7;
  font-size: 28rpx;
}

.activity-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 26rpx;
}

.activity-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  background: #fff4eb;
  color: #ea580c;
  font-size: 25rpx;
  box-shadow: inset 0 0 0 2rpx rgba(251, 146, 60, 0.14);
}

.tag-primary {
  background: #effcf5;
  color: #15803d;
  box-shadow: inset 0 0 0 2rpx rgba(22, 163, 74, 0.14);
}

.recommend-tag {
  background: #fef3c7;
  color: #92400e;
  box-shadow: inset 0 0 0 2rpx rgba(245, 158, 11, 0.14);
}

.join-btn {
  min-width: 190rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(34, 197, 94, 0.24);
}

.join-btn::after {
  border: none;
}

.joined-btn {
  background: linear-gradient(135deg, #eef2f7, #e2e8f0);
  color: #475569;
  box-shadow: none;
}

.activity-meta {
  margin-top: 16rpx;
  color: #94a3b8;
  line-height: 1.6;
  font-size: 25rpx;
}

.empty-text {
  color: #9ca3af;
  text-align: center;
  padding: 36rpx 0;
}
