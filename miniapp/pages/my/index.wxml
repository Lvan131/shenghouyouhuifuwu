<view class="container">
  <view wx:if="{{guestMode}}" class="card profile-card guest-card">
    <view class="nickname">欢迎来到校园优惠</view>
    <view class="user-no">登录后即可查看活动、订阅商家和管理个人信息</view>
    <view class="guest-actions">
      <button class="edit-btn" size="mini" bindtap="logout">前往登录页</button>
    </view>
  </view>

  <block wx:else>
    <view class="card profile-card">
      <view class="nickname">{{profile.realName || '微信用户'}}</view>
      <view class="user-no">学工号：{{profile.userNo || '未完善'}}</view>
      <view class="user-no">身份：{{profile.userType === 'TEACHER' ? '教师' : '学生'}}</view>
      <view class="profile-actions">
        <button class="edit-btn" size="mini" bindtap="openEdit">完善资料</button>
        <button class="ghost-btn" size="mini" bindtap="openPasswordDialog">修改密码</button>
      </view>
    </view>

    <view class="section-row">
      <view class="section-title">我的优惠</view>
      <view class="more-link" bindtap="goOffers">查看全部</view>
    </view>
    <block wx:if="{{offersPreview.length}}">
      <block wx:for="{{offersPreview}}" wx:key="recordId">
        <view class="card preview-card" bindtap="goOffers">
          <view class="preview-title">{{item.title}}</view>
          <view class="preview-meta">状态：{{item.status === 'JOINED' ? '已报名' : '已取消'}}</view>
          <view class="preview-meta">时间：{{item.joinTime}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty-card">暂无报名活动</view>

    <view class="section-row">
      <view class="section-title">我的订阅</view>
      <view class="more-link" bindtap="goSubscriptions">查看全部</view>
    </view>
    <block wx:if="{{subscriptionsPreview.length}}">
      <block wx:for="{{subscriptionsPreview}}" wx:key="subscriptionId">
        <view class="card preview-card" bindtap="goSubscriptions">
          <view class="preview-title">{{item.merchantName}}</view>
          <view class="preview-meta">{{item.merchantType}}</view>
          <view class="preview-meta">{{item.address}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty-card">暂无订阅商家</view>

    <button class="logout-btn" bindtap="logout">退出登录</button>
  </block>

  <view wx:if="{{editVisible}}" class="mask">
    <view class="dialog">
      <view class="dialog-title">完善个人信息</view>
      <input class="dialog-input" placeholder="姓名" value="{{form.realName}}" data-field="realName" bindinput="onFieldInput" />
      <input class="dialog-input" placeholder="学号/工号" value="{{form.userNo}}" data-field="userNo" bindinput="onFieldInput" />
      <picker mode="selector" range="{{['学生', '教师']}}" bindchange="onTypeChange" value="{{form.userType === 'TEACHER' ? 1 : 0}}">
        <view class="dialog-input">身份：{{form.userType === 'TEACHER' ? '教师' : '学生'}}</view>
      </picker>
      <input class="dialog-input" placeholder="手机号" value="{{form.phone}}" data-field="phone" bindinput="onFieldInput" />
      <view class="dialog-actions">
        <button size="mini" bindtap="closeEdit">取消</button>
        <button size="mini" type="primary" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>

  <view wx:if="{{passwordVisible}}" class="mask">
    <view class="dialog">
      <view class="dialog-title">修改密码</view>
      <input class="dialog-input" password placeholder="当前密码" value="{{passwordForm.oldPassword}}" data-field="oldPassword" bindinput="onPasswordInput" />
      <input class="dialog-input" password placeholder="新密码" value="{{passwordForm.newPassword}}" data-field="newPassword" bindinput="onPasswordInput" />
      <view class="dialog-actions">
        <button size="mini" bindtap="closePasswordDialog">取消</button>
        <button size="mini" type="primary" bindtap="savePassword">保存</button>
      </view>
    </view>
  </view>
</view>
