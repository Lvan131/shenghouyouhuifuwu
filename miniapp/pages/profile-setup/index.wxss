.setup-page {
  min-height: 100vh;
  padding: 44rpx 28rpx;
  background:
    radial-gradient(circle at top left, rgba(34, 197, 94, 0.14), transparent 28%),
    linear-gradient(180deg, #f6fbff 0%, #eef7f3 46%, #f8fafc 100%);
}

.setup-card {
  margin-top: 90rpx;
  padding: 34rpx 28rpx 32rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 48rpx rgba(15, 23, 42, 0.08);
}

.setup-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
}

.setup-copy {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.7;
}

.setup-input {
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  color: #0f172a;
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
}

.setup-btn {
  height: 88rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 28rpx rgba(34, 197, 94, 0.22);
}

.setup-btn::after {
  border: none;
}
