.merchant-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.merchant-rating {
  margin-top: 8rpx;
  color: #f59e0b;
  font-size: 26rpx;
  font-weight: 600;
}

.paragraph {
  margin-top: 16rpx;
  color: #4b5563;
  line-height: 1.6;
}

.schedule-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f8fafc;
}

.schedule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.schedule-picker {
  margin-top: 16rpx;
  min-height: 82rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid #dbe4ee;
  display: flex;
  align-items: center;
  color: #334155;
}

.schedule-note {
  margin-top: 14rpx;
  color: #64748b;
  line-height: 1.6;
}

.schedule-warning {
  margin-top: 14rpx;
  color: #dc2626;
  line-height: 1.6;
}

.subscribe-btn {
  margin: 0;
  background: #f1f5f9;
  color: #1f2937;
  border-radius: 999rpx;
}

.subscribed-btn {
  background: #dcfce7;
  color: #166534;
}

.primary-btn {
  margin-top: 24rpx;
  background: #2563eb;
  color: #ffffff;
  border-radius: 999rpx;
}

.secondary-btn {
  background: #e5e7eb;
  color: #1f2937;
}

.disabled-btn {
  background: #cbd5e1;
  color: #475569;
}
