.merchant-search-panel {
  margin-bottom: 24rpx;
}

.merchant-search-input {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f4f6f9;
  color: #374151;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 22rpx;
}

.category-track {
  display: inline-flex;
  gap: 18rpx;
}

.category-chip {
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e7ecf2;
  color: #4b5563;
  font-size: 28rpx;
}

.active-chip {
  border-color: #9ae4be;
  background: #effcf5;
  color: #16a34a;
  font-weight: 600;
}

.merchant-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.merchant-main {
  flex: 1;
}

.merchant-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.merchant-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.merchant-distance {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
  color: #059669;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: inset 0 0 0 2rpx rgba(5, 150, 105, 0.08);
}

.merchant-rating {
  margin-top: 10rpx;
  color: #f59e0b;
  font-size: 26rpx;
  font-weight: 600;
}

.merchant-meta {
  margin-top: 10rpx;
  color: #6b7280;
  line-height: 1.6;
}

.subscribe-btn {
  margin: 0;
  padding: 0 26rpx;
  background: #16a34a;
  color: #ffffff;
  border-radius: 999rpx;
}

.subscribe-btn::after {
  border: none;
}

.subscribed-btn {
  background: #eef2f7;
  color: #1f2937;
}

.empty-text {
  color: #9ca3af;
  text-align: center;
  padding: 32rpx 0;
}
